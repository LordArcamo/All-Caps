---
import Logo from "./Logo.astro";
import FooterCol from "./FooterCol.astro";
import { NAV, SITE } from "@data/site";
import { Instagram, Twitter, Youtube } from "lucide-react";
---

<footer class="relative overflow-hidden border-t border-bone/10 bg-black">
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 select-none overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="font-display whitespace-nowrap leading-none text-bone/[0.04]"
      style="font-size: clamp(8rem, 22vw, 22rem); transform: translateY(15%);"
    >
      ALL CAPS · ALL CAPS
    </div>
  </div>

  <div class="relative mx-auto max-w-[1600px] px-6 py-20 lg:px-10">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <Logo />
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-bone/60">
          {SITE.description}
        </p>
        <div class="mt-8 flex gap-3">
          <a
            href={SITE.social.instagram}
            class="grid h-11 w-11 place-items-center rounded-full border border-bone/20 text-bone/60 transition-all hover:border-yellow hover:bg-yellow hover:text-black"
            aria-label="Instagram"
            data-cursor="hover"
          >
            <Instagram size={18} />
          </a>
          <a
            href={SITE.social.twitter}
            class="grid h-11 w-11 place-items-center rounded-full border border-bone/20 text-bone/60 transition-all hover:border-yellow hover:bg-yellow hover:text-black"
            aria-label="Twitter"
            data-cursor="hover"
          >
            <Twitter size={18} />
          </a>
          <a
            href={SITE.social.youtube}
            class="grid h-11 w-11 place-items-center rounded-full border border-bone/20 text-bone/60 transition-all hover:border-yellow hover:bg-yellow hover:text-black"
            aria-label="YouTube"
            data-cursor="hover"
          >
            <Youtube size={18} />
          </a>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-6 lg:col-span-5">
        <FooterCol title="SHOP" items={NAV.footer.shop} />
        <FooterCol title="COMPANY" items={NAV.footer.company} />
        <FooterCol title="SUPPORT" items={NAV.footer.support} />
      </div>

      <div class="lg:col-span-3">
        <h4 class="font-display text-sm tracking-widest text-bone/40">
          NEWSLETTER
        </h4>
        <p class="mt-3 text-sm text-bone/60">
          Get first dibs on drops. Hate it? One click out.
        </p>
        <form class="mt-5 flex gap-2">
          <input
            type="email"
            placeholder="you@anywhere.com"
            class="flex-1 rounded-full border border-bone/20 bg-bone/5 px-4 py-3 text-sm text-bone placeholder:text-bone/40 focus:border-yellow focus:outline-none"
          />
          <button
            type="submit"
            class="rounded-full bg-yellow px-5 py-3 font-display text-xs tracking-widest text-black transition hover:bg-bone"
            data-cursor="hover"
          >
            JOIN
          </button>
        </form>
      </div>
    </div>

    <div
      class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-bone/10 pt-8 text-xs text-bone/40 lg:flex-row lg:items-center"
    >
      <p>
        © {new Date().getFullYear()} {SITE.name}. Made loud in {SITE.address}.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-yellow">Privacy</a>
        <a href="/terms" class="hover:text-yellow">Terms</a>
        <a href="/accessibility" class="hover:text-yellow">Accessibility</a>
      </div>
    </div>
  </div>
</footer>
