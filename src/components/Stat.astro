---
import AnimatedCounter from "@components/react/AnimatedCounter.tsx";

interface Props {
  label: string;
  value: string;
}
const { label, value } = Astro.props;
---

<div class="flex flex-col gap-1">
  <span class="font-mono text-[10px] tracking-widest text-bone/40">{label}</span>
  <span class="font-display text-3xl tracking-tight text-bone lg:text-4xl">
    <AnimatedCounter client:visible value={value} />
  </span>
</div>
