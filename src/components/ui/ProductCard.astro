---
import type { Product } from "@data/products";
import { ArrowUpRight } from "lucide-react";
import WishlistHeart from "@components/react/WishlistHeart.tsx";

interface Props {
  product: Product;
  index?: number;
}
const { product, index = 0 } = Astro.props;
const primary = product.images[0];
const hover = product.images[1] ?? product.images[0];

// Detect whether the image src points at a real generated asset (not a placeholder path).
// Real assets live in /products/*.png. If file doesn't exist Astro will 404 the request
// but the fallback gradient + SVG below will still render underneath.
const heroSrc = product.images[0]?.src ?? "";
const hasGeneratedHero = heroSrc.endsWith(".png");
---

<a
  href={`/product/${product.slug}`}
  class="group relative block"
  data-cursor="hover"
  data-product-card
  style={`--card-index: ${index}`}
>
  <div class="relative aspect-[4/5] w-full overflow-hidden rounded-2xl bg-graphite">
    {/* Tag stack */}
    <div class="absolute left-4 top-4 z-10 flex flex-col gap-2">
      {product.isNew && (
        <span class="rounded-full bg-yellow px-3 py-1 font-display text-[10px] tracking-widest text-black">
          NEW
        </span>
      )}
      {product.isHot && (
        <span class="rounded-full bg-red px-3 py-1 font-display text-[10px] tracking-widest text-bone">
          HOT
        </span>
      )}
      {product.soldOut && (
        <span class="rounded-full bg-black/80 px-3 py-1 font-display text-[10px] tracking-widest text-bone">
          SOLD OUT
        </span>
      )}
      {product.compareAt && !product.soldOut && (
        <span class="rounded-full bg-red px-3 py-1 font-display text-[10px] tracking-widest text-bone">
          -{Math.round(((product.compareAt - product.price) / product.compareAt) * 100)}%
        </span>
      )}
    </div>

    {/* Drop tag + wishlist */}
    <div class="absolute right-4 top-4 z-10 flex items-center gap-2">
      <div class="grid h-9 w-9 place-items-center rounded-full bg-black/60 backdrop-blur">
        <WishlistHeart client:visible product={product} size={14} />
      </div>
      <span class="rounded-full border border-bone/30 bg-black/40 px-3 py-1 font-mono text-[10px] tracking-wider text-bone/80 backdrop-blur">
        {product.drop}
      </span>
    </div>

    {/* Primary image */}
    {hasGeneratedHero ? (
      <img
        src={heroSrc}
        alt={primary.alt}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-all duration-700 ease-out group-hover:scale-110"
      />
    ) : (
      <div
        class="absolute inset-0 bg-cover bg-center transition-all duration-700 ease-out group-hover:scale-110 group-hover:opacity-0"
        style={`background-image: linear-gradient(135deg, ${product.colors[0]?.hex ?? "#222"}40, #0a0a0a 70%), radial-gradient(circle at 30% 40%, ${product.colors[0]?.hex ?? "#222"}, #0a0a0a 70%);`}
        role="img"
        aria-label={primary.alt}
      />
    )}

    {/* Hover image (alt color/angle) */}
    <div
      class="absolute inset-0 bg-cover bg-center opacity-0 transition-all duration-700 ease-out group-hover:scale-110 group-hover:opacity-100"
      style={`background-image: radial-gradient(circle at 70% 60%, ${product.colors[1]?.hex ?? product.colors[0]?.hex}, #0a0a0a 75%);`}
      aria-hidden="true"
    />

    {/* Logo placeholder (until real images load) */}
    {!hasGeneratedHero && (
    <div class="pointer-events-none absolute inset-0 grid place-items-center">
      <svg viewBox="0 0 120 80" class="h-24 w-auto opacity-90 mix-blend-multiply">
        <path d="M10 50 L30 15 L50 15 L70 50 Z" fill="#0A0A0A" />
        <path
          d="M30 50 Q60 60 110 50 Q100 65 60 70 Q25 65 10 55 Z"
          fill={product.colors[0]?.hex ?? "#FFCC00"}
        />
        <text
          x="40"
          y="42"
          font-family="Anton, Bebas Neue, sans-serif"
          font-size="28"
          fill={product.colors[0]?.hex ?? "#FFCC00"}
          font-weight="900"
          font-style="italic"
        >
          AC
        </text>
      </svg>
    </div>
    )}

    {/* Color dots */}
    <div class="absolute bottom-4 left-4 z-10 flex gap-1.5">
      {product.colors.map((c) => (
        <span
          class="h-3 w-3 rounded-full border border-bone/30"
          style={`background: ${c.hex}`}
          title={c.name}
        />
      ))}
    </div>

    {/* Quick-add reveal */}
    <div class="absolute inset-x-4 bottom-4 z-10 translate-y-4 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
      <div class="flex items-center justify-between rounded-full bg-yellow px-4 py-3 font-display text-xs tracking-widest text-black">
        <span>QUICK ADD</span>
        <ArrowUpRight size={14} />
      </div>
    </div>

    {/* Noise overlay */}
    <div class="pointer-events-none absolute inset-0 opacity-30 mix-blend-overlay">
      <svg width="100%" height="100%">
        <filter id={`noise-${product.slug}`}>
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.9"
            numOctaves="2"
          />
        </filter>
        <rect width="100%" height="100%" filter={`url(#noise-${product.slug})`} />
      </svg>
    </div>
  </div>

  {/* Info */}
  <div class="mt-4 flex items-start justify-between gap-4">
    <div>
      <h3 class="font-display text-xl tracking-tight text-bone">{product.name}</h3>
      <p class="mt-1 text-xs uppercase tracking-wider text-bone/50">
        {product.tagline}
      </p>
    </div>
    <div class="text-right">
      {product.compareAt && (
        <span class="block text-xs text-bone/40 line-through">
          ${product.compareAt}
        </span>
      )}
      <span class="font-display text-xl text-yellow">${product.price}</span>
    </div>
  </div>
</a>
