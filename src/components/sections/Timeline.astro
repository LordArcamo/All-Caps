---
const events = [
  {
    when: "FEB 2025",
    title: "Three people, $30K, an idea.",
    body: "Jesse calls Mia. Mia calls Lars. They put their savings on the table and lock the brand name.",
    color: "#FFCC00",
  },
  {
    when: "JUL 2025",
    title: "Brooklyn workshop signed.",
    body: "Old bicycle shop on Bedford Ave. Industrial machines arrive. First prototype: 23 versions of the Void Runner.",
    color: "#FF2D2D",
  },
  {
    when: "NOV 2025",
    title: "Drop 01 — sold out in 17 hours.",
    body: "200 Void Runners, 200 Static Fitteds, 200 Dust Dads, 200 Shadow Beanies. Word of mouth, zero ads.",
    color: "#FFCC00",
  },
  {
    when: "MAR 2026",
    title: "Tokyo workshop opens.",
    body: "Mia moves operations for design + fitting to Shibuya. Drop 02 prototypes begin.",
    color: "#3A3F45",
  },
  {
    when: "MAY 2026",
    title: "Drop 02 — live now.",
    body: "Eight pieces, 1,600 units, three workshops, four humans. Selling out as you read this.",
    color: "#FFCC00",
    highlight: true,
  },
  {
    when: "JUN 2026",
    title: "Drop 03 — locked.",
    body: "Berlin workshop comes online. New silhouettes, same model: 200 per piece, no restocks.",
    color: "#FF2D2D",
    future: true,
  },
];
---

<section class="bg-black py-24 lg:py-32" data-section="timeline">
  <div class="mx-auto max-w-[1300px] px-6 lg:px-10">
    <div class="mb-16">
      <div class="mb-4 flex items-center gap-3 font-mono text-xs tracking-widest text-bone/60">
        <span class="block h-px w-12 bg-yellow"></span>
        <span>FROM ZERO</span>
      </div>
      <h2
        class="font-display tracking-tight"
        style="font-size: clamp(2.5rem, 6vw, 5rem); line-height: 0.9;"
      >
        <span class="block">SIXTEEN MONTHS.</span>
        <span class="block text-yellow italic">SEVEN DROPS.</span>
      </h2>
    </div>

    <div class="relative">
      {/* Vertical line */}
      <div
        class="pointer-events-none absolute left-0 top-0 bottom-0 w-px bg-bone/15 lg:left-[7.5rem]"
        aria-hidden="true"
      ></div>

      <ol class="space-y-12 lg:space-y-16">
        {events.map((e, i) => (
          <li
            class="grid grid-cols-[auto_1fr] gap-6 lg:grid-cols-[7.5rem_auto_1fr] lg:gap-10"
            data-timeline-item
          >
            <span
              class="hidden font-mono text-xs tracking-widest text-bone/40 lg:block"
            >
              {e.when}
            </span>

            {/* Node */}
            <div class="relative">
              <span
                class={`relative z-10 grid h-12 w-12 place-items-center rounded-full ${
                  e.future
                    ? "border-2 border-dashed border-bone/30"
                    : ""
                }`}
                style={!e.future ? `background: ${e.color}; box-shadow: 0 0 0 6px #0a0a0a, 0 0 0 7px ${e.color}33;` : "background: transparent;"}
              >
                {e.highlight && (
                  <span
                    class="absolute inset-0 rounded-full"
                    style={`background: ${e.color}; animation: pulse-ring 2.4s ease-out infinite;`}
                  ></span>
                )}
                <span class="font-display text-base text-black">{String(i + 1).padStart(2, "0")}</span>
              </span>
            </div>

            <div>
              <span class="block font-mono text-xs tracking-widest text-bone/40 lg:hidden">
                {e.when}
              </span>
              <h3 class="mt-1 font-display text-2xl tracking-tight text-bone lg:text-3xl">
                {e.title}
              </h3>
              <p class="mt-3 max-w-2xl text-bone/60">{e.body}</p>
              {e.highlight && (
                <span class="mt-3 inline-block rounded-full bg-yellow px-3 py-1 font-display text-[10px] tracking-widest text-black">
                  ★ YOU ARE HERE
                </span>
              )}
              {e.future && (
                <span class="mt-3 inline-block rounded-full border border-red/40 bg-red/5 px-3 py-1 font-mono text-[10px] tracking-widest text-red">
                  COMING SOON
                </span>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.4); opacity: 0; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.batch("[data-timeline-item]", {
    interval: 0.08,
    start: "top 85%",
    onEnter: (els) =>
      gsap.fromTo(
        els,
        { opacity: 0, x: -30 },
        {
          opacity: 1,
          x: 0,
          duration: 0.8,
          ease: "expo.out",
          stagger: 0.1,
        },
      ),
  });
</script>
