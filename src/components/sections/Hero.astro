---
import Button from "@components/ui/Button.astro";
import Stat from "@components/Stat.astro";
---

<section
  class="relative min-h-[100svh] overflow-hidden bg-black noise-overlay"
  data-section="hero"
>
  {/* Background gradient blob */}
  <div
    class="pointer-events-none absolute -top-40 left-1/2 h-[120vh] w-[120vh] -translate-x-1/2 rounded-full opacity-30 blur-[120px]"
    style="background: radial-gradient(circle, #FFCC00 0%, transparent 70%);"
    aria-hidden="true"
  >
  </div>

  {/* Grid lines */}
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 80px 80px;"
    aria-hidden="true"
  >
  </div>

  {/* Vertical text rail */}
  <div
    class="pointer-events-none absolute left-6 top-1/2 hidden -translate-y-1/2 -rotate-90 origin-left font-mono text-[10px] tracking-[0.4em] text-bone/30 lg:block"
  >
    EST · 2025 — ALL CAPS — BROOKLYN · TOKYO · BERLIN
  </div>
  <div
    class="pointer-events-none absolute right-6 top-1/2 hidden -translate-y-1/2 rotate-90 origin-right font-mono text-[10px] tracking-[0.4em] text-bone/30 lg:block"
  >
    DROP 02 / VOL. 03 — SCROLL TO ENTER
  </div>

  <div
    class="relative mx-auto flex min-h-[100svh] max-w-[1600px] flex-col justify-center px-6 pb-20 pt-40 lg:px-10"
  >
    {/* Eyebrow */}
    <div
      class="mb-8 flex items-center gap-3 font-mono text-xs tracking-widest text-bone/60"
      data-hero-eyebrow
    >
      <span class="block h-px w-12 bg-yellow"></span>
      <span>DROP 02 — LIVE NOW</span>
    </div>

    {/* Massive headline */}
    <h1
      class="font-display leading-[0.85] tracking-tight"
      style="font-size: clamp(4rem, 13vw, 13rem);"
      data-hero-headline
    >
      <span class="block overflow-hidden">
        <span class="block text-bone" data-hero-line>HEADS UP.</span>
      </span>
      <span class="block overflow-hidden">
        <span class="block text-yellow italic" data-hero-line
          >CAPS ON.</span
        >
      </span>
      <span class="block overflow-hidden">
        <span class="block text-stroke" data-hero-line>VOLUME LOUD.</span>
      </span>
    </h1>

    {/* Sub + CTA row */}
    <div
      class="mt-12 flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between"
    >
      <p
        class="max-w-md text-base leading-relaxed text-bone/70 lg:text-lg"
        data-hero-sub
      >
        Built in Brooklyn. Cut sharp. Stitched louder. The new drop is here —
        eight pieces, two hundred made, when they're gone they're gone.
      </p>

      <div class="flex flex-wrap gap-3" data-hero-ctas>
        <Button href="/shop" variant="primary" size="lg" arrow>
          SHOP DROP 02
        </Button>
        <Button href="/lookbook" variant="outline" size="lg">
          THE LOOKBOOK
        </Button>
      </div>
    </div>

    {/* Stats bar */}
    <div
      class="mt-20 grid grid-cols-2 gap-6 border-t border-bone/10 pt-8 lg:grid-cols-4"
      data-hero-stats
    >
      <Stat label="DROPS SHIPPED" value="07" />
      <Stat label="EDITIONS MADE" value="200" />
      <Stat label="CITIES SERVED" value="42" />
      <Stat label="RAW SCORE" value="4.9/5" />
    </div>

    {/* Scroll cue */}
    <div
      class="absolute inset-x-0 bottom-8 flex justify-center"
      aria-hidden="true"
    >
      <div
        class="flex flex-col items-center gap-2 font-mono text-[10px] tracking-widest text-bone/50"
      >
        <span>SCROLL</span>
        <span class="block h-12 w-px bg-bone/30">
          <span class="block h-6 w-px bg-yellow" data-scroll-cue></span>
        </span>
      </div>
    </div>
  </div>
</section>

{/* Inline component: Stat */}
<style is:global>
  [data-hero-line] {
    transform: translateY(110%);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Intro timeline
  const tl = gsap.timeline({
    defaults: { ease: "expo.out" },
    delay: 0.1,
  });

  tl.to("[data-hero-eyebrow]", {
    opacity: 1,
    y: 0,
    duration: 0.8,
  })
    .fromTo(
      "[data-hero-line]",
      { y: "110%" },
      {
        y: "0%",
        duration: 1.1,
        stagger: 0.08,
      },
      "-=0.4",
    )
    .from(
      "[data-hero-sub]",
      {
        opacity: 0,
        y: 30,
        duration: 0.8,
      },
      "-=0.5",
    )
    .from(
      "[data-hero-ctas] > *",
      {
        opacity: 0,
        y: 20,
        duration: 0.6,
        stagger: 0.08,
      },
      "-=0.5",
    )
    .from(
      "[data-hero-stats] > *",
      {
        opacity: 0,
        y: 20,
        duration: 0.5,
        stagger: 0.05,
      },
      "-=0.3",
    );

  // Scroll cue pulse
  gsap.to("[data-scroll-cue]", {
    y: 18,
    duration: 1.4,
    ease: "expo.inOut",
    repeat: -1,
    yoyo: true,
  });
</script>
