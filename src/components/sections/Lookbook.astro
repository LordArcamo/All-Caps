---
import Button from "@components/ui/Button.astro";

const tiles = [
  {
    title: "STREET",
    edition: "VOL. 01",
    sub: "Brooklyn — golden hour",
    tone: "#FFCC00",
    span: "lg:col-span-5 lg:row-span-2",
    aspect: "aspect-[3/4]",
    href: "/lookbook/street",
    accent: "left",
    quote: "WORN IN THE WILD",
  },
  {
    title: "GRID",
    edition: "VOL. 02",
    sub: "Tokyo — neon noir",
    tone: "#FF2D2D",
    span: "lg:col-span-4",
    aspect: "aspect-square",
    href: "/lookbook/grid",
    accent: "top",
  },
  {
    title: "RAW",
    edition: "VOL. 03",
    sub: "Berlin — concrete",
    tone: "#3A3F45",
    span: "lg:col-span-3",
    aspect: "aspect-[3/4]",
    href: "/lookbook/raw",
    accent: "right",
  },
  {
    title: "FIELD",
    edition: "VOL. 04",
    sub: "Off-grid — desert",
    tone: "#D9C9A8",
    span: "lg:col-span-7",
    aspect: "aspect-[16/9]",
    href: "/lookbook/field",
    accent: "left",
    quote: "INTO THE WIDE OPEN",
  },
  {
    title: "WATER",
    edition: "VOL. 05",
    sub: "Coastal — overcast",
    tone: "#5E7585",
    span: "lg:col-span-5",
    aspect: "aspect-square",
    href: "/lookbook/water",
    accent: "top",
  },
  {
    title: "NIGHT",
    edition: "VOL. 06",
    sub: "After hours",
    tone: "#0A0A0A",
    span: "lg:col-span-4",
    aspect: "aspect-square",
    href: "/lookbook/night",
    accent: "right",
  },
  {
    title: "STILLS",
    edition: "VOL. 07",
    sub: "Studio — no people",
    tone: "#FFCC00",
    span: "lg:col-span-3",
    aspect: "aspect-square",
    href: "/lookbook/stills",
    accent: "top",
  },
];
---

<section
  class="relative bg-black py-32 lg:py-48"
  data-section="lookbook"
>
  <div class="mx-auto max-w-[1600px] px-6 lg:px-10">
    <div class="mb-16 flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-end">
      <div>
        <div class="mb-4 flex items-center gap-3 font-mono text-xs tracking-widest text-bone/60">
          <span class="block h-px w-12 bg-yellow"></span>
          <span>LOOKBOOK — 7 VOLUMES</span>
        </div>
        <h2 class="font-display tracking-tight" style="font-size: clamp(2.5rem, 7vw, 6rem);">
          <span class="block">WORN.</span>
          <span class="block text-yellow italic">EVERYWHERE.</span>
        </h2>
      </div>
      <Button href="/lookbook" variant="ghost" arrow>BROWSE THE FULL BOOK</Button>
    </div>

    {/* Bento grid */}
    <div class="grid grid-cols-1 gap-4 lg:auto-rows-[280px] lg:grid-cols-12 lg:gap-5">
      {tiles.map((tile, i) => (
        <a
          href={tile.href}
          class:list={[
            "group relative overflow-hidden rounded-3xl bg-graphite",
            tile.aspect,
            tile.span,
          ]}
          data-bento-tile
          style={`--tile-tone: ${tile.tone}; --tile-index: ${i};`}
          data-cursor="hover"
        >
          {/* Background gradient */}
          <div
            class="absolute inset-0 transition-transform duration-[1.2s] ease-out group-hover:scale-110"
            style={`background: radial-gradient(circle at 30% 30%, ${tile.tone}70, #0a0a0a 70%), linear-gradient(135deg, ${tile.tone}40, #0a0a0a);`}
          ></div>
          <div class="pointer-events-none absolute inset-0 noise-overlay opacity-30"></div>

          {/* Big background letter */}
          <div
            class="pointer-events-none absolute inset-0 grid place-items-center font-display text-bone/[0.07] transition-transform duration-1000 group-hover:scale-105"
            style="font-size: clamp(5rem, 12vw, 14rem); line-height: 0.8;"
          >
            {tile.title[0]}
          </div>

          {/* Top-right edition tag */}
          <span class="absolute right-5 top-5 rounded-full border border-bone/30 bg-black/40 px-3 py-1 font-mono text-[10px] tracking-widest text-bone/80 backdrop-blur">
            {tile.edition}
          </span>

          {/* Yellow corner accent */}
          {tile.accent === "left" && (
            <span class="absolute left-0 top-0 h-12 w-1 bg-yellow transition-all duration-500 group-hover:h-24"></span>
          )}
          {tile.accent === "top" && (
            <span class="absolute left-5 top-0 h-1 w-12 bg-yellow transition-all duration-500 group-hover:w-24"></span>
          )}
          {tile.accent === "right" && (
            <span class="absolute right-0 top-0 h-12 w-1 bg-yellow transition-all duration-500 group-hover:h-24"></span>
          )}

          {/* Bottom gradient + info */}
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent p-6 lg:p-8">
            <span class="font-mono text-[10px] tracking-widest text-bone/60">
              {tile.sub}
            </span>
            <h3
              class="mt-2 font-display tracking-tight text-bone"
              style="font-size: clamp(1.75rem, 3.5vw, 3.5rem); line-height: 0.9;"
            >
              {tile.title}.
            </h3>
            {tile.quote && (
              <p class="mt-3 max-w-[20ch] text-sm text-bone/70 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                "{tile.quote}"
              </p>
            )}
            <div
              class="mt-4 flex items-center gap-2 text-xs font-display tracking-widest text-yellow opacity-0 transition-all duration-500 group-hover:opacity-100"
            >
              <span>OPEN VOLUME</span>
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.batch("[data-bento-tile]", {
    interval: 0.06,
    start: "top 88%",
    onEnter: (els) =>
      gsap.fromTo(
        els,
        { opacity: 0, y: 60, scale: 0.96 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1.0,
          ease: "expo.out",
          stagger: 0.06,
        },
      ),
  });
</script>
