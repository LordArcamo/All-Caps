---
import Button from "@components/ui/Button.astro";

const tiles = [
  {
    title: "STREET / 01",
    sub: "Brooklyn — golden hour",
    tone: "#FFCC00",
    aspect: "aspect-[3/4]",
    span: "lg:col-span-7 lg:row-span-2",
    href: "/lookbook/street",
  },
  {
    title: "GRID / 02",
    sub: "Tokyo — neon noir",
    tone: "#FF2D2D",
    aspect: "aspect-square",
    span: "lg:col-span-5",
    href: "/lookbook/grid",
  },
  {
    title: "RAW / 03",
    sub: "Berlin — concrete",
    tone: "#3A3F45",
    aspect: "aspect-[5/4]",
    span: "lg:col-span-5",
    href: "/lookbook/raw",
  },
  {
    title: "FIELD / 04",
    sub: "Off-grid — desert",
    tone: "#D9C9A8",
    aspect: "aspect-[3/2]",
    span: "lg:col-span-12",
    href: "/lookbook/field",
  },
];
---

<section
  class="relative bg-black py-32 lg:py-48"
  data-section="lookbook"
>
  <div class="mx-auto max-w-[1600px] px-6 lg:px-10">
    <div class="mb-16 flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-end">
      <div>
        <div class="mb-4 flex items-center gap-3 font-mono text-xs tracking-widest text-bone/60">
          <span class="block h-px w-12 bg-yellow"></span>
          <span>LOOKBOOK — VOL.03</span>
        </div>
        <h2 class="font-display tracking-tight" style="font-size: clamp(2.5rem, 7vw, 6rem);">
          <span class="block">WORN.</span>
          <span class="block text-yellow italic">EVERYWHERE.</span>
        </h2>
      </div>
      <Button href="/lookbook" variant="ghost" arrow>BROWSE THE FULL BOOK</Button>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-12 lg:gap-6">
      {tiles.map((tile) => (
        <a
          href={tile.href}
          class:list={[
            "group relative overflow-hidden rounded-3xl bg-graphite",
            tile.aspect,
            tile.span,
          ]}
          data-lookbook-tile
          data-cursor="hover"
        >
          <div
            class="absolute inset-0 transition-transform duration-1000 ease-out group-hover:scale-110"
            style={`background: radial-gradient(circle at 30% 30%, ${tile.tone}80, #0a0a0a 70%), linear-gradient(135deg, ${tile.tone}40, #0a0a0a);`}
          />
          <div class="pointer-events-none absolute inset-0 noise-overlay opacity-30"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

          <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
            <span class="font-mono text-xs tracking-widest text-bone/60">
              {tile.sub}
            </span>
            <h3
              class="mt-2 font-display tracking-tight text-bone"
              style="font-size: clamp(2rem, 4vw, 4rem);"
            >
              {tile.title}
            </h3>
            <div
              class="mt-4 flex items-center gap-2 text-sm text-yellow opacity-0 transition-all duration-500 group-hover:opacity-100"
            >
              <span class="font-display tracking-widest">EXPLORE</span>
              <span>→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.batch("[data-lookbook-tile]", {
    interval: 0.08,
    start: "top 85%",
    onEnter: (els) =>
      gsap.fromTo(
        els,
        { opacity: 0, y: 60, scale: 0.96 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1.0,
          ease: "expo.out",
          stagger: 0.1,
        },
      ),
  });
</script>
