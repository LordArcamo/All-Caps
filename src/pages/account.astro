---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import Stat from "@components/Stat.astro";
import SidebarLink from "@components/SidebarLink.astro";
import { LogOut, Truck } from "lucide-react";

const MOCK_ORDERS = [
  {
    id: "AC-2078",
    date: "APR 14, 2026",
    status: "DELIVERED",
    statusColor: "text-bone/60",
    statusBg: "bg-bone/10",
    total: 130,
    items: [
      { name: "VOID RUNNER", color: "Jet", price: 65, hex: "#0A0A0A" },
      { name: "SHADOW BEANIE", color: "Hype Yellow", price: 38, hex: "#FFCC00" },
      { name: "STATIC FITTED", color: "Bone", price: 75, hex: "#F5F5F0" },
    ],
  },
  {
    id: "AC-2104",
    date: "APR 28, 2026",
    status: "SHIPPED",
    statusColor: "text-yellow",
    statusBg: "bg-yellow/10",
    total: 70,
    items: [{ name: "HALO SNAP", color: "Bone", price: 70, hex: "#F5F5F0" }],
  },
  {
    id: "AC-2156",
    date: "MAY 12, 2026",
    status: "PROCESSING",
    statusColor: "text-red",
    statusBg: "bg-red/10",
    total: 113,
    items: [
      { name: "DUST DAD", color: "Sand", price: 48, hex: "#D9C9A8" },
      { name: "GRID TRUCKER", color: "Black/Yellow", price: 55, hex: "#FFCC00" },
    ],
  },
];
---

<Layout title="Your account" description="Manage your orders, shipping, and preferences.">
  <section class="relative bg-black pt-40 pb-12">
    <div class="mx-auto max-w-[1300px] px-6 lg:px-10">
      <div class="mb-4 flex items-center gap-3 font-mono text-xs tracking-widest text-bone/60">
        <span class="block h-px w-12 bg-yellow"></span>
        <span>HELLO, JESSE</span>
      </div>
      <h1
        class="font-display tracking-tight"
        style="font-size: clamp(2.5rem, 7vw, 7rem); line-height: 0.85;"
      >
        YOUR <span class="italic text-yellow">ORDERS.</span>
      </h1>
    </div>
  </section>

  <section class="bg-black pb-20">
    <div class="mx-auto grid max-w-[1300px] gap-8 px-6 lg:grid-cols-12 lg:px-10">
      {/* Sidebar */}
      <aside class="lg:col-span-3">
        <div class="rounded-3xl border border-bone/10 bg-ink p-6">
          {/* Profile */}
          <div class="flex items-center gap-4 border-b border-bone/10 pb-5">
            <div class="grid h-14 w-14 place-items-center rounded-full bg-yellow font-display text-2xl text-black">
              JO
            </div>
            <div class="min-w-0">
              <p class="font-display text-lg tracking-tight">JESSE OKONKWO</p>
              <p class="font-mono text-[10px] tracking-widest text-bone/40">
                MEMBER · DROP 01
              </p>
            </div>
          </div>

          <nav class="mt-5 space-y-1">
            <SidebarLink icon="orders" label="ORDERS" active count={3} />
            <SidebarLink icon="address" label="ADDRESSES" count={2} />
            <SidebarLink icon="payment" label="PAYMENT" count={1} />
            <SidebarLink icon="alerts" label="DROP ALERTS" count={4} />
            <SidebarLink icon="settings" label="PREFERENCES" />
          </nav>

          <button class="mt-6 flex w-full items-center justify-center gap-2 rounded-full border border-bone/10 py-2.5 font-mono text-[10px] tracking-widest text-bone/40 hover:border-red hover:text-red">
            <LogOut size={12} />
            SIGN OUT
          </button>
        </div>

        {/* Quick stats */}
        <div class="mt-6 grid grid-cols-2 gap-3">
          <div class="rounded-2xl border border-bone/10 bg-ink p-4">
            <p class="font-mono text-[10px] tracking-widest text-bone/40">CAPS OWNED</p>
            <p class="mt-1 font-display text-3xl text-yellow">
              <Stat label="" value="06" />
            </p>
          </div>
          <div class="rounded-2xl border border-bone/10 bg-ink p-4">
            <p class="font-mono text-[10px] tracking-widest text-bone/40">SAVED</p>
            <p class="mt-1 font-display text-3xl text-yellow">
              <Stat label="" value="313" />
            </p>
            <p class="-mt-1 font-mono text-[9px] tracking-widest text-bone/30">USD LIFETIME</p>
          </div>
        </div>
      </aside>

      {/* Orders */}
      <div class="lg:col-span-9">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="font-display text-2xl tracking-tight">ORDER HISTORY</h2>
          <a href="#" class="font-mono text-[10px] tracking-widest text-bone/40 hover:text-yellow">
            EXPORT CSV →
          </a>
        </div>

        <ul class="space-y-4">
          {MOCK_ORDERS.map((order) => (
            <li class="overflow-hidden rounded-2xl border border-bone/10 bg-ink transition-colors hover:border-yellow/40">
              <div class="flex flex-wrap items-center justify-between gap-4 border-b border-bone/10 px-6 py-4">
                <div class="flex items-center gap-6">
                  <div>
                    <p class="font-mono text-[10px] tracking-widest text-bone/40">ORDER</p>
                    <p class="font-display tracking-wide">{order.id}</p>
                  </div>
                  <div>
                    <p class="font-mono text-[10px] tracking-widest text-bone/40">PLACED</p>
                    <p class="font-mono text-sm text-bone/80">{order.date}</p>
                  </div>
                  <div>
                    <p class="font-mono text-[10px] tracking-widest text-bone/40">TOTAL</p>
                    <p class="font-display text-lg text-yellow">${order.total}</p>
                  </div>
                </div>
                <span class={`rounded-full px-3 py-1 font-display text-[10px] tracking-widest ${order.statusBg} ${order.statusColor}`}>
                  {order.status}
                </span>
              </div>
              <ul class="divide-y divide-bone/5">
                {order.items.map((item) => (
                  <li class="flex items-center gap-4 px-6 py-4">
                    <span
                      class="grid h-14 w-14 shrink-0 place-items-center overflow-hidden rounded-lg"
                      style={`background: radial-gradient(circle, ${item.hex}40, #0a0a0a 80%);`}
                    >
                      <svg viewBox="0 0 120 80" class="h-8 w-auto">
                        <path d="M10 50 L30 15 L50 15 L70 50 Z" fill="#0A0A0A" />
                        <path
                          d="M30 50 Q60 60 110 50 Q100 65 60 70 Q25 65 10 55 Z"
                          fill={item.hex}
                        />
                      </svg>
                    </span>
                    <div class="flex-1">
                      <p class="font-display text-sm tracking-wide">{item.name}</p>
                      <p class="text-xs text-bone/40">{item.color}</p>
                    </div>
                    <p class="font-display text-sm text-yellow">${item.price}</p>
                  </li>
                ))}
              </ul>
              <div class="flex items-center justify-between border-t border-bone/10 bg-bone/[0.02] px-6 py-3">
                <div class="flex items-center gap-2 text-xs text-bone/50">
                  <Truck size={12} />
                  <span>{order.status === "PROCESSING" ? "Ships within 2 business days" : order.status === "SHIPPED" ? "Arriving by May 18" : "Delivered Apr 18"}</span>
                </div>
                <div class="flex gap-2">
                  <button class="rounded-full border border-bone/20 px-3 py-1 font-mono text-[10px] tracking-widest text-bone/60 hover:border-yellow hover:text-yellow">
                    TRACK
                  </button>
                  <button class="rounded-full border border-bone/20 px-3 py-1 font-mono text-[10px] tracking-widest text-bone/60 hover:border-yellow hover:text-yellow">
                    REORDER
                  </button>
                </div>
              </div>
            </li>
          ))}
        </ul>

        {/* Empty state placeholder for additional sections */}
        <div class="mt-12 rounded-3xl border border-dashed border-bone/15 bg-ink/40 p-12 text-center">
          <p class="font-display text-3xl tracking-tight text-bone/40">
            THAT'S THE WHOLE STORY.
          </p>
          <p class="mt-3 text-sm text-bone/40">More orders means more caps. Make it happen.</p>
          <a href="/shop" class="mt-6 inline-flex items-center gap-2 rounded-full bg-yellow px-5 py-2.5 font-display text-xs tracking-widest text-black hover:scale-[1.02]">
            BROWSE THE DROP →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

{/* Sidebar link */}
<style>
  .nav-link.active {
    background: rgba(255, 204, 0, 0.08);
    color: #FFCC00;
  }
</style>
